{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "types": ["jest"],
    "baseUrl": ".",
    "paths": {
      "@domain/*": ["src/@domain/*"],
      "@application/*": ["src/@application/*"],
      "@components/*": ["src/components/*"],
      "@containers/*": ["src/containers/*"],
      "@services/*": ["services/*"],
      "@navigation/*": ["src/navigation/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.d.ts"],
  "exclude": ["**/node_modules", "**/Pods"]
}
